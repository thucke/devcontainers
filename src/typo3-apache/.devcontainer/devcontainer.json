// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "Apache, PHP ${localEnv:PHP_VERSION}",
	"build": {
		"context": ".",
		"dockerfile": "Dockerfile",
		"args": {
			"COMMIT_SHA": "${localEnv:COMMIT_SHA}",
			"DEVCONTAINER_SERVICE_NAME": "typo3dev",
			"DEVCONTAINER_SERVICE_ID": "10000",
			"IMAGE_BASE_DIGEST": "${localEnv:IMAGE_BASE_DIGEST}",
			"IMAGE_BASE_NAME": "${localEnv:IMAGE_BASE_NAME}",
			"IMAGE_BASE_NAME_LABEL": "${localEnv:IMAGE_BASE_NAME}:${localEnv:IMAGE_BASE_TAG}",
			"IMAGE_BASE_TAG": "${localEnv:IMAGE_BASE_TAG}",
			"IMAGE_TIMESTAMP": "${localEnv:IMAGE_TIMESTAMP}",
			"IMAGE_VERSION": "${localEnv:NEXT_CALVER}",
			"MATRIX_FOLDER": "${localEnv:MATRIX_FOLDER}",
			"PHP_VERSION": "${localEnv:PHP_VERSION}"
		},
		"options": [
			"--tag=${localEnv:TARGET_IMAGE_NAME}:${localEnv:TARGET_IMAGE_BASETAG}",
			"--tag=${localEnv:TARGET_IMAGE_NAME}:${localEnv:TARGET_IMAGE_BASETAG}-${localEnv:NEXT_CALVER}"
		]
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode-remote.remote-containers"
			],
			"settings": {
				"debug.openDebug": "openOnDebugBreak",
				"debug.internalConsoleOptions": "openOnSessionStart",
				"extensions.autoUpdate": false,
				"editor.selectionHighlight": false,
				"editor.suggestSelection": "first",
				"editor.tabCompletion": "onlySnippets",
				"editor.wordBasedSuggestions": "off",
				"editor.codeActionsOnSave": {
					"source.fixAll.markdownlint": "explicit"
				},
				"files.autoSave": "afterDelay",
				"files.autoSaveDelay": 1000,
				"files.eol": "\n",
				"files.trimTrailingWhitespace": true,
				"files.insertFinalNewline": true,
				"git.autofetch": true,
				"git.postCommitCommand": "push",
				"git.path": "/usr/bin/git",
				"gitAutoStage.enable": true
			}
		}
	}
}
